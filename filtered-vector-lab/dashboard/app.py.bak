# -----------------------------------------------------------------------------
# 页面 4：算法对比 (Recall-QPS 帕累托分析)
# -----------------------------------------------------------------------------
def page_algorithm(df: pd.DataFrame):
    st.markdown('<div class="page-title">Recall-QPS 帕累托分析</div>', unsafe_allow_html=True)
    st.markdown('<div class="page-subtitle">分析不同过滤向量算法在召回率与吞吐量之间的性能权衡关系。</div>', unsafe_allow_html=True)
    
    # 顶部筛选条
    c1, c2, c3, c4, c5, c6 = st.columns([1, 1, 1, 1, 1, 0.5])
    with c1: st.selectbox("数据集", ["SIFT1M", "synthetic-small"], index=0)
    with c2: st.selectbox("查询数", ["10k", "1k", "100k"])
    with c3: st.selectbox("k", [10, 5, 20, 100])
    with c4: st.selectbox("过滤类型", ["Window", "Predicate"])
    with c5: st.selectbox("Recall 阈值", ["0.90", "0.95", "0.99"])
    with c6: 
        st.markdown("<div style='height:28px;'></div>", unsafe_allow_html=True)
        st.button("🔄", key="ref2")

    col_l, col_r = st.columns([2.5, 1])
    
    with col_l:
        st.markdown('**Recall-QPS 帕累托前沿** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        if not df.empty and "algo_display" in df.columns:
            fig1 = px.scatter(df, x="recall", y="qps", color="algo_display", color_discrete_map=ALGO_COLORS, log_y=True)
            # Try to draw Pareto front
            try:
                from src.storage.result_store import load_normalized_csv
                pareto_df = df.sort_values("recall").copy()
                pareto_pts = []
                max_qps = -1
                for _, row in pareto_df.iterrows():
                    if row["qps"] > max_qps:
                        pareto_pts.append(row)
                        max_qps = row["qps"]
                if pareto_pts:
                    pdf = pd.DataFrame(pareto_pts)
                    fig1.add_trace(go.Scatter(x=pdf["recall"], y=pdf["qps"], mode="lines", name="Pareto 前沿", line=dict(dash="dash", color="#64748b")))
            except:
                pass
        else:
            # Mock data
            x_vals = np.random.uniform(0.75, 1.0, 50)
            y_vals = np.random.uniform(10, 100000, 50)
            algos = np.random.choice(list(ALGO_COLORS.keys()), 50)
            mock_df = pd.DataFrame({"recall": x_vals, "qps": y_vals, "algo_display": algos})
            fig1 = px.scatter(mock_df, x="recall", y="qps", color="algo_display", color_discrete_map=ALGO_COLORS, log_y=True)
            
        fig1.update_layout(height=350, margin=dict(l=0, r=0, t=10, b=0), plot_bgcolor="#fff", paper_bgcolor="#fff", legend=dict(orientation="h", yanchor="bottom", y=1.02))
        st.plotly_chart(fig1, use_container_width=True, config={'displayModeBar': False})
        
    with col_r:
        st.markdown('**选中算法详情**')
        st.markdown("""
        <div class="stCard" style="padding: 1rem; border-top: 3px solid #10b981;">
            <div style="font-weight: 600; color: #1e293b; margin-bottom: 5px;">优化后 HNSW</div>
            <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 15px;">参数配置: ef=200, M=32</div>
            <table style="width:100%; font-size:0.85rem; border-collapse:collapse;">
                <tr><td style="padding:4px 0; color:#64748b;">Recall@10</td><td style="text-align:right; font-weight:600;">0.952</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">QPS (查询/秒)</td><td style="text-align:right; font-weight:600;">2,450</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">平均延迟 (ms)</td><td style="text-align:right; font-weight:600;">0.42</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">构建时间 (s)</td><td style="text-align:right; font-weight:600;">1,680</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">内存占用 (GB)</td><td style="text-align:right; font-weight:600;">18.3</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">过滤宽度 w</td><td style="text-align:right; font-weight:600;">128</td></tr>
                <tr><td style="padding:4px 0; color:#64748b;">选择率 (selectivity)</td><td style="text-align:right; font-weight:600;">0.082 (8.2%)</td></tr>
            </table>
        </div>
        <div class="stCard" style="padding: 1rem;">
            <div style="font-weight: 600; color: #1e293b; margin-bottom: 10px; font-size: 0.9rem;">Pareto 最优候选</div>
            <table style="width:100%; font-size:0.8rem; border-collapse:collapse;">
                <tr style="border-bottom:1px solid #eee; color:#64748b;"><th style="padding:4px;">排名</th><th style="padding:4px;">算法</th><th style="padding:4px;">综合得分</th></tr>
                <tr><td style="padding:4px;">🥇</td><td style="padding:4px;">优化后 HNSW</td><td style="padding:4px;"><div style="background:#10b981; height:6px; width:90%; border-radius:3px;"></div></td></tr>
                <tr><td style="padding:4px;">🥈</td><td style="padding:4px;">Window Search Tree</td><td style="padding:4px;"><div style="background:#f59e0b; height:6px; width:85%; border-radius:3px;"></div></td></tr>
                <tr><td style="padding:4px;">🥉</td><td style="padding:4px;">SIEVE</td><td style="padding:4px;"><div style="background:#8b5cf6; height:6px; width:83%; border-radius:3px;"></div></td></tr>
            </table>
        </div>
        """, unsafe_allow_html=True)
        
    c7, c8 = st.columns([1.5, 1])
    with c7:
        st.markdown('**实验点明细** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        table_data = pd.DataFrame({
            "算法": ["HNSW", "优化后 HNSW", "Window Search Tree", "SIEVE", "Prefilter", "Postfilter"],
            "参数": ["ef=100", "ef=200", "β=8", "target=0.95", "α=0.8", "ef=400"],
            "Recall@10": [0.874, 0.952, 0.944, 0.951, 0.915, 0.985],
            "QPS": [6300, 2450, 1880, 2050, 1280, 620],
            "延迟 (ms)": [0.28, 0.42, 0.58, 0.49, 0.61, 1.82],
            "内存 (GB)": [12.4, 18.3, 20.7, 16.8, 24.6, 30.1],
            "构建时间 (s)": [950, 1680, 2450, 1420, 1250, 980]
        })
        st.dataframe(table_data, use_container_width=True, hide_index=True)
        
    with c8:
        st.markdown('**综合指标对比** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        categories = ['Recall@10', 'QPS (log)', '延迟 (log)', '内存 (GB)', '构建时间 (log)']
        fig2 = go.Figure()
        for algo, col in zip(["HNSW", "优化后 HNSW", "Window Search Tree", "SIEVE"], ["#1a73e8", "#10b981", "#f59e0b", "#8b5cf6"]):
            fig2.add_trace(go.Scatterpolar(
                r=np.random.uniform(0.4, 1.0, 5), theta=categories, fill='toself', name=algo, line_color=col, opacity=0.4
            ))
        fig2.update_layout(
            polar=dict(radialaxis=dict(visible=True, range=[0, 1])),
            showlegend=True, height=260, margin=dict(l=30, r=30, t=20, b=20),
            legend=dict(orientation="h", yanchor="bottom", y=1.05)
        )
        st.plotly_chart(fig2, use_container_width=True, config={'displayModeBar': False})

