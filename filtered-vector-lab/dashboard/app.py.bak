# =============================================================================
# 数据加载与处理
# =============================================================================
@st.cache_data
def load_all_results():
    p = PROJECT_ROOT / "results" / "normalized" / "all_results.csv"
    if not p.exists():
        merge_all_normalized()
    df = load_normalized_csv(str(p)) if p.exists() else pd.DataFrame()
    
    # 映射算法名称到原型图中的名称
    algo_map = {
        "hnsw": "HNSW",
        "prefiltering": "Filtered HNSW (优化型)",
        "vamana-tree": "Window Search Tree",
        "sieve": "SIEVE",
        "postfiltering": "折中型",
        "acorngamma": "自适应型"
    }
    if not df.empty and "algorithm" in df.columns:
        df["algo_display"] = df["algorithm"].map(algo_map).fillna(df["algorithm"])
    return df

@st.cache_data
def load_detail_data(dataset: str = "synthetic-small"):
    p = PROJECT_ROOT / "results" / "raw" / "hnswlib" / dataset / "detail.parquet"
    return pd.read_parquet(p) if p.exists() else pd.DataFrame()

# 统一颜色映射
ALGO_COLORS = {
    "HNSW": "#1a73e8",
    "Filtered HNSW (优化型)": "#10b981",
    "Window Search Tree": "#f59e0b",
    "SIEVE": "#8b5cf6",
    "折中型": "#059669",
    "自适应型": "#ec4899"
}

def render_kpi(title, value, sub_text, icon, icon_bg="#e0e7ff", icon_color="#1a73e8", is_negative=False):
    sub_class = "kpi-sub negative" if is_negative else "kpi-sub"
    return f"""
    <div class="kpi-box">
        <div class="kpi-icon-wrapper" style="background-color: {icon_bg}; color: {icon_color};">{icon}</div>
        <div class="kpi-content">
            <div class="kpi-title">{title}</div>
            <div class="kpi-value">{value}</div>
            <div class="{sub_class}">{sub_text}</div>
        </div>
    </div>
    """

# =============================================================================
# 页面组件
# =============================================================================
def render_sidebar():
    with st.sidebar:
        st.markdown("""
        <div style="padding: 20px 20px 10px 20px;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
                <div style="width: 32px; height: 32px; background: #1a73e8; border-radius: 8px; display: flex; justify-content: center; align-items: center; color: white; font-weight: bold; font-size: 1.2rem;">
                    H
                </div>
                <div>
                    <div style="color: white; font-weight: 700; font-size: 1.1rem; line-height: 1.2;">HNSW-Filter</div>
                    <div style="color: #94a3b8; font-size: 0.75rem; line-height: 1.2;">向量检索优化平台</div>
                </div>
            </div>
        </div>
        """, unsafe_allow_html=True)
        
        NAV_ITEMS = [
            ("🏠 系统总览", "系统总览"),
            ("🗄️ 数据集管理", "数据集管理"),
            ("⚡ 索引构建", "索引构建"),
            ("🔍 查询检索", "查询检索"),
            ("🎯 过滤策略分析", "过滤策略分析"),
            ("⏱️ 性能评测", "性能评测"),
            ("📊 算法对比", "算法对比"),
            ("⚙️ 系统设置", "系统设置")
        ]
        
        if "nav" not in st.session_state:
            st.session_state.nav = "性能评测"
            
        nav_labels = [item[0] for item in NAV_ITEMS]
        nav_map = {item[0]: item[1] for item in NAV_ITEMS}
        
        try:
            default_idx = list(nav_map.values()).index(st.session_state.nav)
        except ValueError:
            default_idx = 5
            
        sel = st.radio("", nav_labels, index=default_idx, label_visibility="collapsed")
        st.session_state.nav = nav_map[sel]
        
        st.markdown("""
        <div style="position: absolute; bottom: 20px; left: 20px; right: 20px;">
            <div style="background: rgba(26, 115, 232, 0.1); border-radius: 8px; padding: 15px; border: 1px solid rgba(26, 115, 232, 0.2);">
                <div style="color: #60a5fa; font-size: 0.75rem; font-weight: 600; margin-bottom: 4px;">基于 HNSW 的</div>
                <div style="color: white; font-size: 0.85rem; font-weight: 600; line-height: 1.4;">过滤向量检索优化<br>方法研究与实现</div>
            </div>
            <div style="margin-top: 15px; display: flex; align-items: center; gap: 8px;">
                <div style="width: 8px; height: 8px; border-radius: 50%; background: #10b981;"></div>
                <span style="color: #94a3b8; font-size: 0.75rem;">系统运行正常</span>
                <span style="color: #64748b; font-size: 0.7rem; margin-left: auto;">版本: v1.0.0</span>
            </div>
        </div>
        """, unsafe_allow_html=True)

# -----------------------------------------------------------------------------
# 页面 1：性能评测 (构建时间与内存开销分析)
# -----------------------------------------------------------------------------
def page_performance(df: pd.DataFrame):
    st.markdown('<div class="page-title">构建时间与内存开销分析</div>', unsafe_allow_html=True)
    st.markdown('<div class="page-subtitle">从索引构建成本与资源占用角度比较不同过滤向量检索算法的开销差异。</div>', unsafe_allow_html=True)
    
    # 顶部筛选条
    c1, c2, c3, c4, c5 = st.columns([1.5, 1.5, 1.5, 1.5, 0.5])
    with c1: st.selectbox("数据集", ["SIFT1M", "synthetic-small", "GIST"], index=1)
    with c2: st.selectbox("指标视图", ["Build+Memory", "Only Build", "Only Memory"])
    with c3: st.selectbox("算法范围", ["全部", "HNSW", "SIEVE", "Window Search Tree"])
    with c4: st.selectbox("测试批次", ["latest run", "run-20240501", "run-20240415"])
    with c5: 
        st.markdown("<div style='height:28px;'></div>", unsafe_allow_html=True)
        st.button("🔄")
        
    # Mock some metrics based on df or static if df empty
    build_avg = df["build_time_s"].mean() / 60 if not df.empty and not df["build_time_s"].isna().all() else 38.6
    mem_avg = df["memory_kb"].mean() / (1024*1024) if not df.empty and not df["memory_kb"].isna().all() else 24.8
    
    # KPI 区域
    kpi_html = f"""
    <div class="kpi-container">
        {render_kpi("平均构建时间", f"{build_avg:.1f} min", "较上次 +8.2 min (17.5%)", "⏱️", "#e0e7ff", "#1a73e8", True)}
        {render_kpi("平均内存占用", f"{mem_avg:.1f} GB", "较上次 +3.6 GB (12.7%)", "💾", "#dcfce7", "#10b981", True)}
        {render_kpi("最优综合成本算法", "折中型", "综合成本指数: 0.82 (超越极优)", "🏆", "#f3e8ff", "#8b5cf6")}
    </div>
    """
    st.markdown(kpi_html, unsafe_allow_html=True)
    
    # 图表区域 1
    col1, col2 = st.columns(2)
    
    if not df.empty:
        agg_df = df.groupby("algo_display").agg({
            "build_time_s": "mean", "memory_kb": "mean", "index_size_kb": "mean", "recall": "max", "qps": "max"
        }).reset_index()
        agg_df["build_min"] = agg_df["build_time_s"] / 60
        agg_df["memory_gb"] = agg_df["memory_kb"] / (1024*1024)
        agg_df["index_gb"] = agg_df["index_size_kb"] / (1024*1024)
        # Handle NaN for visualization
        agg_df.fillna({"build_min": 0, "memory_gb": 0, "index_gb": 0}, inplace=True)
    else:
        # Fallback to prototype data
        agg_df = pd.DataFrame({
            "algo_display": ["HNSW", "Filtered HNSW (优化型)", "Window Search Tree", "SIEVE", "折中型", "自适应型"],
            "build_time_s": [93.2, 96.8, 94.1, 1880, 2450, 18.3],
            "memory_gb": [24.6, 18.3, 20.7, 16.8, 14.2, 10.1],
            "index_gb": [24.6, 18.3, 20.7, 16.8, 14.2, 10.1],
            "recall": [0.724, 0.805, 0.848, 0.885, 0.948, 0.969],
            "qps": [12800, 1280, 1680, 2050, 2450, 18300]
        })
        agg_df["build_min"] = agg_df["build_time_s"] / 60
        
    # Sort as in prototype
    order = ["HNSW", "Filtered HNSW (优化型)", "Window Search Tree", "SIEVE", "折中型", "自适应型"]
    agg_df["algo_display"] = pd.Categorical(agg_df["algo_display"], categories=order, ordered=True)
    agg_df = agg_df.sort_values("algo_display")
    
    with col1:
        st.markdown('**索引构建时间对比** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        fig1 = go.Figure()
        fig1.add_trace(go.Bar(
            x=agg_df["algo_display"], y=agg_df["build_time_s"], name="时间 (s)",
            marker_color="#1a73e8", text=agg_df["build_time_s"].apply(lambda x: f"{x:.1f} s"), textposition="outside"
        ))
        fig1.update_layout(height=280, margin=dict(l=0, r=0, t=30, b=0), showlegend=True, legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1), yaxis_type="log", plot_bgcolor="#fff", paper_bgcolor="#fff")
        fig1.update_yaxes(showgrid=True, gridcolor="#f1f5f9")
        st.plotly_chart(fig1, use_container_width=True, config={'displayModeBar': False})
        
    with col2:
        st.markdown('**内存 / 索引大小对比** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        fig2 = go.Figure()
        fig2.add_trace(go.Bar(
            x=agg_df["algo_display"], y=agg_df["memory_gb"], name="Memory (GB)",
            marker_color="#1a73e8", text=agg_df["memory_gb"].apply(lambda x: f"{x:.1f}"), textposition="outside"
        ))
        fig2.add_trace(go.Bar(
            x=agg_df["algo_display"], y=agg_df["index_gb"], name="Index Size (GB)",
            marker_color="#10b981", text=agg_df["index_gb"].apply(lambda x: f"{x:.1f}"), textposition="outside"
        ))
        fig2.update_layout(height=280, barmode="group", margin=dict(l=0, r=0, t=30, b=0), showlegend=True, legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1), yaxis_type="log", plot_bgcolor="#fff", paper_bgcolor="#fff")
        fig2.update_yaxes(showgrid=True, gridcolor="#f1f5f9")
        st.plotly_chart(fig2, use_container_width=True, config={'displayModeBar': False})

    # 图表区域 2
    col3, col4 = st.columns([1.5, 1])
    
    with col3:
        st.markdown('**Recall-QPS-Memory 三维权衡** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        fig3 = px.scatter(
            agg_df, x="recall", y="qps", size="memory_gb", color="algo_display",
            color_discrete_map=ALGO_COLORS, size_max=30, log_y=True
        )
        fig3.update_layout(height=260, margin=dict(l=0, r=0, t=30, b=0), plot_bgcolor="#fff", paper_bgcolor="#fff", legend_title="")
        fig3.update_xaxes(showgrid=True, gridcolor="#f1f5f9")
        fig3.update_yaxes(showgrid=True, gridcolor="#f1f5f9")
        st.plotly_chart(fig3, use_container_width=True, config={'displayModeBar': False})
        
    with col4:
        st.markdown('**成本分析结论** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        st.markdown("""
        <div class="insight-box">
            <ul>
                <li><b>折中型</b>在构建时间与内存占用之间取得最佳平衡，综合成本最低 (0.82)。</li>
                <li><b>自适应型</b>在 QPS 与 Recall 上表现最佳，但构建时间与内存开销较高。</li>
                <li><b>SIEVE</b>构建耗时较长且内存占用最高，综合成本不具优势。</li>
                <li><b>Window Search Tree</b>与 <b>Filtered HNSW (优化型)</b> 在时间上更优，但 Recall 略低。</li>
                <li>建议在通用场景优先选用折中型，在高精度需求场景考虑自适应型。</li>
            </ul>
        </div>
        """, unsafe_allow_html=True)

    # 资源开销明细表
    st.markdown('**资源开销明细** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
    table_df = agg_df[["algo_display", "build_time_s", "index_gb", "memory_gb", "recall", "qps"]].copy()
    table_df.columns = ["算法", "构建时间 (s)", "Index Size (GB)", "Memory (GB)", "Recall@10", "QPS (查询/秒)"]
    table_df["备注"] = ["基线 HNSW 索引", "过滤范围优化", "窗口搜索树结构", "多条件连接增强", "时间与内存的均衡最优解", "自适应过滤与搜索调度"]
    
    st.dataframe(
        table_df.style.format({
            "构建时间 (s)": "{:.1f}", "Index Size (GB)": "{:.1f}", "Memory (GB)": "{:.1f}", 
            "Recall@10": "{:.3f}", "QPS (查询/秒)": "{:,.0f}"
        }),
        use_container_width=True, hide_index=True
    )

# -----------------------------------------------------------------------------
# 页面 2：查询检索 (单查询 Top-k 结果解释)
# -----------------------------------------------------------------------------
def page_query(df: pd.DataFrame):
    st.markdown('<div class="page-title">单查询 Top-k 结果解释</div>', unsafe_allow_html=True)
    st.markdown('<div class="page-subtitle">面向单个查询展示不同算法返回结果、过滤条件满足情况及召回表现。</div>', unsafe_allow_html=True)
    
    c1, c2, c3, c4, c5, c6 = st.columns([1, 1, 1, 0.8, 1, 1])
    with c1: st.text_input("Query ID", value="q_1024")
    with c2: st.selectbox("算法选择", ["SIEVE", "HNSW", "Window Search Tree"])
    with c3: st.selectbox("数据集", ["SIFT1M", "synthetic-small"])
    with c4: st.number_input("k", value=10)
    with c5: st.text_input("过滤条件", value="[1000, 5000]")
    with c6: 
        st.markdown("<div style='height:28px;'></div>", unsafe_allow_html=True)
        st.toggle("与 HNSW 对比", value=True)
        
    col_l, col_m, col_r = st.columns([1, 1.5, 1.2])
    
    with col_l:
        st.markdown("""
        <div class="stCard" style="padding: 1rem;">
            <div style="font-weight: 600; margin-bottom: 15px; color: #1e293b;">查询信息</div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">👤 Query ID</span><span style="color: #1a73e8; font-weight: 500;">q_1024</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">🔣 过滤范围</span><span style="color: #1a73e8; font-weight: 500;">[1000, 5000]</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">⏱️ 查询延迟 (ms)</span><span style="color: #1a73e8; font-weight: 500;">18.7</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">🎯 Recall@10 (%)</span><span style="color: #1a73e8; font-weight: 500;">90.0%</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">✅ 命中数量 (Hit@10)</span><span style="color: #1a73e8; font-weight: 500;">9 / 10</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">📊 选择率 (Selectivity)</span><span style="color: #1a73e8; font-weight: 500;">0.412%</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.85rem;">
                <span style="color: #64748b;">📏 向量范数 (L2)</span><span style="color: #1a73e8; font-weight: 500;">23.657</span>
            </div>
        </div>
        <div class="stCard" style="padding: 1rem;">
            <div style="font-weight: 600; margin-bottom: 10px; color: #1e293b; font-size: 0.9rem;">延迟趋势 (最近 20 次)</div>
            <!-- Mock sparkline -->
            <div style="height: 60px; background: url('https://upload.wikimedia.org/wikipedia/commons/thumb/c/c5/Sparkline_example.svg/200px-Sparkline_example.svg.png') no-repeat center; background-size: cover; opacity: 0.6;"></div>
        </div>
        """, unsafe_allow_html=True)
        
    with col_m:
        st.markdown("**Top-k 检索结果**")
        res_df = pd.DataFrame({
            "rank": range(1, 11),
            "vector_id": ["423,118", "156,892", "887,455", "321,004", "773,210", "204,559", "692,771", "118,336", "915,002", "301,885"],
            "distance": [0.2418, 0.2683, 0.2746, 0.2912, 0.3157, 0.3329, 0.3563, 0.3845, 0.4216, 0.4789],
            "满足过滤": ["✅"]*10,
            "命中真值": ["✅"]*9 + ["❌"],
            "score": [0.7582, 0.7317, 0.7254, 0.7088, 0.6843, 0.6671, 0.6437, 0.6155, 0.5784, 0.5211]
        })
        st.dataframe(res_df, use_container_width=True, hide_index=True)
        
    with col_r:
        st.markdown("**Ground Truth 对照**")
        gt_df = pd.DataFrame({
            "rank": range(1, 11),
            "vector_id": ["423,118", "156,892", "887,455", "321,004", "773,210", "204,559", "692,771", "118,336", "915,002", "444,090"],
            "distance": [0.2418, 0.2683, 0.2746, 0.2912, 0.3157, 0.3329, 0.3563, 0.3845, 0.4216, 0.4491],
            "在结果中": ["✅"]*9 + ["❌"]
        })
        st.dataframe(gt_df, use_container_width=True, hide_index=True)
        
        st.markdown("""
        <div class="stCard" style="padding: 1rem; margin-top: 10px;">
            <div style="font-weight: 600; margin-bottom: 10px; color: #1e293b; font-size: 0.9rem;">算法对比摘要</div>
            <table style="width:100%; font-size:0.8rem; text-align:left; border-collapse:collapse;">
                <tr style="border-bottom:1px solid #eee; color:#64748b;"><th style="padding:4px;">指标</th><th style="padding:4px;">当前算法 (SIEVE)</th><th style="padding:4px;">HNSW</th><th style="padding:4px;">差值 (SIEVE - HNSW)</th></tr>
                <tr style="border-bottom:1px solid #eee;"><td style="padding:4px;">Recall@10 (%)</td><td style="padding:4px; color:#10b981;">90.0%</td><td style="padding:4px;">78.0%</td><td style="padding:4px; color:#10b981;">+12.0 pp</td></tr>
                <tr style="border-bottom:1px solid #eee;"><td style="padding:4px;">查询延迟 (ms)</td><td style="padding:4px;">18.7</td><td style="padding:4px; color:#10b981;">12.4</td><td style="padding:4px; color:#ef4444;">+6.3 ms</td></tr>
                <tr><td style="padding:4px;">命中率 (Hit@10)</td><td style="padding:4px; color:#10b981;">9 / 10 (90.0%)</td><td style="padding:4px;">7 / 10 (70.0%)</td><td style="padding:4px; color:#10b981;">+2 (20.0 pp)</td></tr>
            </table>
        </div>
        """, unsafe_allow_html=True)
        
    st.markdown('**结果分布可视化**')
    fig = px.scatter(res_df, x="rank", y="distance", text="distance", color="命中真值", 
                     color_discrete_map={"✅": "#1a73e8", "❌": "#ef4444"})
    fig.update_traces(textposition="top center", marker=dict(size=12))
    for i, row in res_df.iterrows():
        fig.add_shape(type="line", x0=row["rank"], y0=0, x1=row["rank"], y1=row["distance"], line=dict(color="gray", width=1, dash="dot"))
    fig.update_layout(height=250, margin=dict(l=0, r=0, t=20, b=0), plot_bgcolor="#fff", paper_bgcolor="#fff", legend_title="")
    st.plotly_chart(fig, use_container_width=True, config={'displayModeBar': False})

