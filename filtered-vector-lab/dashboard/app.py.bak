# 页面 5：过滤策略分析 (过滤强度敏感性分析)
# -----------------------------------------------------------------------------
def page_filter(df: pd.DataFrame):
    st.markdown('<div class="page-title">过滤强度敏感性分析</div>', unsafe_allow_html=True)
    st.markdown('<div class="page-subtitle">展示过滤窗口宽度或选择率变化时，不同算法性能的敏感性特征。</div>', unsafe_allow_html=True)
    
    c1, c2, c3, c4, c5 = st.columns([1.5, 1.5, 1.5, 1.5, 1.5])
    with c1: st.selectbox("数据集", ["SIFT1M", "synthetic-small"])
    with c2: st.selectbox("策略类型", ["Window Filter", "Predicate"])
    with c3: st.selectbox("度量指标", ["QPS", "Recall@10"])
    with c4: st.selectbox("Recall 阈值", ["0.90", "0.95"])
    with c5: st.selectbox("视图", ["热力图 + 趋势图"])
    
    col_l, col_r = st.columns([2, 1])
    
    with col_l:
        st.markdown('**不同过滤宽度下的最优 QPS 热力图** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        hm_data = pd.DataFrame({
            "2^-16": [0.32, 0.45, 0.61, 0.58, 0.18, 0.22],
            "2^-12": [0.78, 1.12, 1.86, 1.78, 0.41, 0.52],
            "2^-8": [1.92, 2.71, 4.62, 4.20, 0.86, 1.12],
            "2^-4": [3.86, 5.13, 8.87, 8.46, 1.62, 2.12],
            "2^0": [6.12, 7.68, 12.9, 12.3, 2.90, 3.78]
        }, index=["HNSW", "Optimized HNSW", "Window Search Tree (β-WST)", "SIEVE", "Prefilter", "Postfilter"])
        
        fig1 = px.imshow(hm_data, text_auto=True, color_continuous_scale="RdYlBu_r", aspect="auto")
        fig1.update_layout(height=240, margin=dict(l=0, r=0, t=10, b=0), coloraxis_showscale=False)
        st.plotly_chart(fig1, use_container_width=True, config={'displayModeBar': False})
        
    with col_r:
        st.markdown('**结论摘要** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        st.markdown("""
        <div class="insight-box">
            <ul>
                <li>在极低选择率 (≤ 2⁻⁸) 下，<b>β-WST</b> 与 <b>SIEVE</b> 相比其他算法保持显著优势，QPS 提升 2-5 倍。</li>
                <li>在中等选择率 (2⁻⁸~2⁻²) 区间，<b>β-WST</b> 与 <b>SIEVE</b> 仍能维持最高吞吐，其中 <b>β-WST</b> 整体领先更明显。</li>
                <li>在高选择率 (≥ 2⁻²) 时，<b>SIEVE</b> 与 <b>β-WST</b> 接近平台期，优势减弱；此时 <b>HNSW/Optimized HNSW</b> 性能差距缩小。</li>
            </ul>
            <div style="font-size:0.75rem; color:#94a3b8; margin-top:10px;">注：结论基于 Recall ≥ 0.90 的约束条件。</div>
        </div>
        """, unsafe_allow_html=True)
        
    col_b1, col_b2 = st.columns([2, 1])
    with col_b1:
        st.markdown('**过滤强度变化趋势** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        # Mock trend
        x_lbls = ["2^-16", "2^-12", "2^-8", "2^-4", "2^0"]
        fig2 = go.Figure()
        for i, (algo, col) in enumerate(zip(hm_data.index, ["#1a73e8", "#10b981", "#f59e0b", "#8b5cf6", "#ec4899", "#64748b"])):
            fig2.add_trace(go.Scatter(x=x_lbls, y=hm_data.iloc[i]*1000, mode='lines+markers', name=algo, line=dict(color=col)))
        fig2.update_layout(height=280, margin=dict(l=0, r=0, t=10, b=0), plot_bgcolor="#fff", paper_bgcolor="#fff", legend=dict(orientation="h", yanchor="bottom", y=1.02))
        fig2.update_yaxes(showgrid=True, gridcolor="#f1f5f9")
        st.plotly_chart(fig2, use_container_width=True, config={'displayModeBar': False})
        
    with col_b2:
        st.markdown('**关键转折点** <span class="title-icon">ⓘ</span>', unsafe_allow_html=True)
        tp_df = pd.DataFrame({
            "选择率": ["0.0015%", "0.39%", "6.25%", "25%", "100%"],
            "过滤宽度": ["2^-16", "2^-8", "2^-4", "2^-2", "2^0"],
            "最优算法": ["β-WST", "β-WST", "β-WST", "SIEVE", "SIEVE"],
            "QPS": [610, 4620, 8870, 11200, 12300],
            "Recall@10": [0.909, 0.912, 0.905, 0.904, 0.907]
        })
        st.dataframe(tp_df, use_container_width=True, hide_index=True)

# =============================================================================
# 路由控制
# =============================================================================
def main():
    st.set_page_config(page_title="过滤向量检索可视化平台", layout="wide", initial_sidebar_state="expanded")
    st.markdown(CUSTOM_CSS, unsafe_allow_html=True)
    
    render_sidebar()
    df = load_all_results()
    
    page = st.session_state.nav
    if page == "性能评测":
        page_performance(df)
    elif page == "系统总览":
        page_overview(df)
    elif page == "查询检索":
        page_query(df)
    elif page == "算法对比":
        page_algorithm(df)
    elif page == "过滤策略分析":
        page_filter(df)
    else:
        st.info(f"【{page}】模块开发中...")

if __name__ == "__main__":
    main()
